# ============================
# Auth
# ============================
NOFX_LOCAL_AUTH_KEY=change_me_local_auth_key

# ============================
# Server
# ============================
HOST=0.0.0.0
PORT=30007
DEBUG=false

# ============================
# Binance (read-only, optional)
# ============================
BINANCE_API_KEY_READONLY=
BINANCE_API_SECRET_READONLY=

# ============================
# Hyperliquid (market data itself does not require these)
# ============================
HYPERLIQUID_ADDRESS=
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_DEX=

# ============================
# Macro providers
# ============================
MARKET_DATA_PROVIDER=auto
COINGECKO_API_KEY=
CMC_PRO_API_KEY=
CMC_PRO_API_ENDPOINT=https://pro-api.coinmarketcap.com

# ============================
# Provider usage / free-tier guardrails
# ============================
PROVIDER_USAGE_FILE=data/provider_usage.json
COINGECKO_MONTHLY_SOFT_LIMIT=9500
COINGECKO_MINUTE_SOFT_LIMIT=25
CMC_MONTHLY_SOFT_LIMIT=9500
CMC_MINUTE_SOFT_LIMIT=25

# ============================
# Cache
# ============================
CACHE_WARMUP_ENABLED=true
CACHE_WARMUP_TTL=1800
SNAPSHOT_DIR=data
SNAPSHOT_FILE=data/provider_snapshots.json
